# ─── Convex (Required for cloud sync — app works without it in local mode) ────
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ─── Auth secret (generate with: openssl rand -base64 32) ────────────────────
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# ─── TTS Providers (ALL optional — browser speech is always the fallback) ─────
# ElevenLabs — highest quality
NEXT_PUBLIC_ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Groq TTS + LLaMA (very generous free tier)
NEXT_PUBLIC_GROQ_API_KEY=

# ─── AI Features (ALL optional — regex fallbacks built in) ───────────────────
# Google Gemini Flash — text chunking + mood detection
NEXT_PUBLIC_GEMINI_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
